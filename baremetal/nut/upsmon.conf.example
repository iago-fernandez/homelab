MONITOR myups@localhost 1 upsmon_user <REDACTED_UPSMON_PASSWORD> primary
MINSUPPLIES 1
SHUTDOWNCMD "docker compose -f /home/iago/raspberry-homelab/docker/docker-compose.yml down && /sbin/shutdown -h +0"
POLLFREQ 5
POLLFREQALERT 5
HOSTSYNC 15
DEADTIME 15
RBWARNTIME 43200
NOCOMMWARNTIME 300
FINALDELAY 5
POWERDOWNFLAG /etc/killpower
