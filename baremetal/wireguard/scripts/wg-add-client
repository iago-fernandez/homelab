#!/bin/bash
set -euo pipefail

# Ensure the script runs with root privileges
[ "$EUID" -eq 0 ] || exec sudo "$0" "$@"

name="${1:-}"
endpoint="${2:-}"

# Validate input name
[ -n "$name" ] || { echo "Usage: wg-add-client <name> [endpoint]"; exit 1; }
[[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] && [[ "$name" != .* ]] && [[ "$name" != *".."* ]] || { echo "Invalid name format"; exit 2; }

WG=/etc/wireguard
srv_if=wg0
srv_conf="$WG/$srv_if.conf"

[ -f "$srv_conf" ] || { echo "Missing $srv_conf"; exit 3; }
command -v wg >/dev/null || { echo "wireguard-tools not found"; exit 3; }

# Get endpoint from file if not provided as argument
[ -n "$endpoint" ] || { [ -f "$WG/WG_ENDPOINT" ] && endpoint="$(cat "$WG/WG_ENDPOINT")"; }
[ -n "$endpoint" ] || { echo "Endpoint required (IP_or_domain:port)"; exit 4; }

# Get server public key
srv_pub="$(wg show "$srv_if" public-key 2>/dev/null || true)"
[ -n "$srv_pub" ] || { [ -f "$WG/keys/server.pub" ] && srv_pub="$(tr -d '\n' < "$WG/keys/server.pub")"; }
[ -n "$srv_pub" ] || { echo "Could not obtain server public key"; exit 5; }

# Assign next available IP in 10.8.0.0/24
used="$(wg show "$srv_if" allowed-ips 2>/dev/null | awk '{sub(/\/32$/,"",$2);print $2}')"
for i in $(seq 2 254); do
    ip="10.8.0.$i"
    grep -qx "$ip" <<<"$used" || break
done
[ -n "${ip:-}" ] || { echo "No available IPs in 10.8.0.0/24"; exit 6; }

# Create client directory and generate keys
dir="$WG/clients/$name"
install -d -m700 "$dir"
umask 077
wg genkey > "$dir/private.key"
wg pubkey < "$dir/private.key" > "$dir/public.key"
wg genpsk  > "$dir/psk.key"

priv="$(tr -d '\n' < "$dir/private.key")"
psk="$(tr -d '\n' < "$dir/psk.key")"
pub="$(tr -d '\n' < "$dir/public.key")"

# Register peer in runtime and save configuration
wg set "$srv_if" peer "$pub" preshared-key "$dir/psk.key" allowed-ips "$ip/32"
wg-quick save "$srv_if" >/dev/null 2>&1 || true

# Function to generate client configuration files
gen() {
  cat >"$2"<<CONF
[Interface]
PrivateKey = $priv
Address = $ip/32
# DNS points to the router to resolve .lan records
DNS = 192.168.1.1
MTU = 1420

[Peer]
PublicKey = $srv_pub
PresharedKey = $psk
Endpoint = $endpoint
AllowedIPs = $3
PersistentKeepalive = 25
CONF
  chmod 600 "$2"
}

# Generate both Full and Split tunnel configs
gen full  "$dir/$name-full.conf"  "0.0.0.0/0, ::/0"
gen split "$dir/$name-split.conf" "10.8.0.0/24, 192.168.1.0/24"

echo "Success: $name ($ip) created in $dir"

# Display QR codes automatically after creation
/etc/wireguard/scripts/wg-show-qr "$name"
